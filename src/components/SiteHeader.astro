---

<header class="topbar">
  <div class="topbar-left">
    <button class="listen-pill" type="button">
      <span class="listen-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M4 14v-2a8 8 0 0 1 16 0v2"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
          />
          <path
            d="M4 14v3a2 2 0 0 0 2 2h1v-7H6a2 2 0 0 0-2 2Zm14-2h-1v7h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2Z"
            fill="currentColor"
          />
        </svg>
      </span>
      <span>5,810</span>
      <span class="listen-play">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8 5.5v13l11-6.5L8 5.5Z" fill="currentColor" />
        </svg>
      </span>
    </button>
    <nav class="nav-links" aria-label="Sections">
      <a href="/world">
        World
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <path
            d="M4 6l4 4 4-4"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
          />
        </svg>
      </a>
      <a href="/business">
        Business
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <path
            d="M4 6l4 4 4-4"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
          />
        </svg>
      </a>
      <a href="/lifestyle">
        Lifestyle
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <path
            d="M4 6l4 4 4-4"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
          />
        </svg>
      </a>
    </nav>
  </div>

  <a class="logo" href="/">
    <strong>Sonar</strong> Mag
  </a>

  <div class="topbar-right">
    <a class="subscribe-pill" href="/subscribe">
      Subscribe for €2.50
      <svg viewBox="0 0 16 16" aria-hidden="true">
        <path
          d="M4.5 11.5 11.5 4.5M6 4.5h5.5V10"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </a>
    <button class="menu-btn" type="button" aria-label="Open menu">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M4 7h16M4 12h16M4 17h16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
        />
      </svg>
    </button>
  </div>
</header>
