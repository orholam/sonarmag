---
import { ArticleView } from '../../components/ArticleView.tsx'
import { CommentsSection } from '../../components/CommentsSection.tsx'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { fetchArticleBySlug, fetchCommentsForArticle } from '../../lib/api'
import { articleJsonLd, breadcrumbJsonLd, categoryPath } from '../../lib/seo'

export const prerender = false

const { slug } = Astro.params
if (!slug) {
  return Astro.redirect('/')
}

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=30, stale-while-revalidate=120',
)

const article = await fetchArticleBySlug(slug)
const comments = article ? await fetchCommentsForArticle(article.id) : []

if (!article) {
  Astro.response.status = 404
}
---

{!article ? (
  <BaseLayout
    title="Article not found"
    description="That story may have moved or never existed."
    path={`/article/${slug}`}
    noIndex
  >
    <main class="article-missing">
      <h1>Article not found</h1>
      <p>That story may have moved or never existed.</p>
      <a href="/">Back to Sonar Mag</a>
    </main>
  </BaseLayout>
) : (
  <BaseLayout
    title={article.title}
    description={article.excerpt || article.paragraphs[0] || undefined}
    path={`/article/${article.slug}`}
    image={article.heroImage}
    type="article"
    publishedAt={article.publishedAt}
    author={article.author}
    section={article.category}
    jsonLd={[
      articleJsonLd(article),
      breadcrumbJsonLd([
        { name: 'Home', path: '/' },
        ...(categoryPath(article.category)
          ? [{ name: article.category, path: categoryPath(article.category)! }]
          : []),
        { name: article.title, path: `/article/${article.slug}` },
      ]),
    ]}
  >
    <main>
      <ArticleView article={article} />
      <div class="article-shell">
        <div class="article-main article-main-continue">
          <CommentsSection
            client:load
            articleId={article.id}
            initialComments={comments}
          />
        </div>
      </div>
    </main>
  </BaseLayout>
)}
