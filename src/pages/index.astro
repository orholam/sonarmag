---
import { HomeBoard } from '../components/HomeBoard.tsx'
import BaseLayout from '../layouts/BaseLayout.astro'
import { fetchHomepageData } from '../lib/api'
import { organizationJsonLd, websiteJsonLd } from '../lib/seo'
import { DEFAULT_DESCRIPTION } from '../lib/site'

export const prerender = false

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=60, stale-while-revalidate=300',
)

const data = await fetchHomepageData()

const splashPrefetch = [
  data.hero,
  data.secondary,
  data.opinion,
  data.privacyCard,
  ...data.latest.slice(0, 4),
  ...data.popular.slice(0, 3),
]
  .filter(Boolean)
  .map((article) => `/article/${article!.slug}`)
const prefetchPaths = [...new Set(splashPrefetch)]
---

<BaseLayout
  title="Sonar Mag"
  description={DEFAULT_DESCRIPTION}
  path="/"
  image={data.hero?.heroImage}
  type="website"
  jsonLd={[organizationJsonLd(), websiteJsonLd()]}
  prefetchPaths={prefetchPaths}
>
  <main>
    <HomeBoard data={data} />
  </main>
</BaseLayout>
