---
import { HomeBoard } from '../components/HomeBoard.tsx'
import BaseLayout from '../layouts/BaseLayout.astro'
import { fetchHomepageData } from '../lib/api'
import { faqJsonLd, organizationJsonLd, websiteJsonLd } from '../lib/seo'
import { DEFAULT_DESCRIPTION } from '../lib/site'

export const prerender = false

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=60, stale-while-revalidate=300',
)

const data = await fetchHomepageData()
const newsletterStatus = Astro.url.searchParams.get('newsletter')

const splashPrefetch = [
  data.hero,
  data.secondary,
  data.opinion,
  data.privacyCard,
  ...data.latest.slice(0, 4),
  ...data.popular.slice(0, 3),
]
  .filter(Boolean)
  .map((article) => `/article/${article!.slug}`)
const prefetchPaths = [...new Set(splashPrefetch)]
---

<BaseLayout
  title="Sonar Mag"
  description={DEFAULT_DESCRIPTION}
  path="/"
  image={data.hero?.heroImage}
  lcpImage={data.hero?.heroImage}
  type="website"
  jsonLd={[
    organizationJsonLd(),
    websiteJsonLd(),
    faqJsonLd([
      {
        question: 'What is Sonar Mag?',
        answer:
          'Sonar Mag is an independent online publication for essays, reporting, and cultural field notes across World, Business, and Lifestyle.',
      },
      {
        question: 'How do I get the Sonar Mag newsletter?',
        answer:
          'Enter your email in the newsletter box on the homepage. You can unsubscribe at any time.',
      },
      {
        question: 'Is Sonar Mag free to read?',
        answer:
          'Yes. Core reporting and essays are free to read on sonarmag.com. Optional membership supports the desk.',
      },
    ]),
  ]}
  prefetchPaths={prefetchPaths}
>
  <main>
    <HomeBoard data={data} newsletterStatus={newsletterStatus} />
  </main>
</BaseLayout>
