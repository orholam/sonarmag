PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
PUBLIC_SITE_URL=https://www.sonarmag.com
# Server-only — never commit a real key; never use PUBLIC_ prefix
OPENROUTER_API_KEY=
# IndexNow (Bing). Key file is also at public/{INDEXNOW_KEY}.txt
INDEXNOW_KEY=a7c3e91f2b4d68a05e17c9f3d8b2a461
# Bearer token for POST /api/indexnow — set a strong secret in production
INDEXNOW_SUBMIT_SECRET=
# Vercel Cron auth for GET /api/cron/sync-popular (Vercel sends Bearer automatically when set)
CRON_SECRET=
# Web Analytics → Popular rail. Create a token with access to the sonarmag project.
VERCEL_API_TOKEN=
# Usually injected on Vercel; set locally for manual sync testing
VERCEL_PROJECT_ID=
# Required when the project lives on a team
VERCEL_TEAM_ID=
